# =====================================================================
# SUSForge — Template de variáveis de ambiente
# Copie para `.env` e personalize. O arquivo `.env` NUNCA é commitado.
#
#   cp .env.example .env
#
# Para regenerar a Fernet key do Airflow (obrigatório em produção):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =====================================================================

# ---------------------------------------------------------------------
# PostgreSQL — superusuário (raiz da instância)
# ---------------------------------------------------------------------
POSTGRES_USER=susforge
POSTGRES_PASSWORD=susforge_change_me
POSTGRES_DB=susforge

# Mapping de portas — somente para o docker-compose
# (POSTGRES_HOST_PORT é a porta EXPOSTA no host; pode ser remapeada
#  livremente sem afetar nada dentro da rede Compose).
POSTGRES_HOST_PORT=5432

# Conexão dos clientes Python (susforge.config.DatabaseSettings)
# Default aponta para o host local (porta exposta).
# Dentro de contêineres da rede Compose, sobrescreva para:
#   SUSFORGE_DB_HOST=postgres
SUSFORGE_DB_HOST=localhost
SUSFORGE_DB_PORT=5432

# Bancos auxiliares (criados pelo init script no primeiro boot)
AIRFLOW_DB_NAME=airflow_db
METABASE_DB_NAME=metabase_db

# ---------------------------------------------------------------------
# Airflow — runtime
# ---------------------------------------------------------------------
# UID usado dentro dos contêineres Airflow. 50000 é o padrão oficial.
# Em hosts Linux, ajuste para `id -u` se quiser que os arquivos em
# airflow/logs sejam de propriedade do usuário do host.
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Porta exposta no host para o webserver
AIRFLOW_PORT=8080

# Admin inicial criado pelo serviço airflow-init
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_change_me
AIRFLOW_ADMIN_EMAIL=admin@susforge.local
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=SUSForge

# Chaves de criptografia — REGENERE em produção
AIRFLOW_FERNET_KEY=Vd3Q1S5xH6Pc8Yl0nB4mWz9tKj7Rf2Au6Eg3Iy8Sx0M=
AIRFLOW_SECRET_KEY=change_me_in_production_super_long_random_string

# ---------------------------------------------------------------------
# Metabase
# ---------------------------------------------------------------------
METABASE_PORT=3000
METABASE_SITE_LOCALE=pt_BR
